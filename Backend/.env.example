# Supabase (same project as your existing frontend)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# NOTE: this backend needs the SERVICE ROLE key, not the anon key used by the
# frontend, because it writes to register_complaints and reads/writes the
# regulation_chunks table directly, bypassing row-level security.

# Grok (x.ai) API
GROK_API_KEY=your_grok_api_key
GROK_API_URL=https://api.x.ai/v1/chat/completions
GROK_MODEL=grok-2-latest

# Server
PORT=5000
